{
  "agentmemory": {
    "PreInvocation": [
      {
        "type": "command",
        "command": "node /root/.local/lib/agentmemory/agy-memory-hook.mjs pre",
        "timeout": 20
      }
    ],
    "PostInvocation": [
      {
        "type": "command",
        "command": "node /root/.local/lib/agentmemory/agy-memory-hook.mjs post",
        "timeout": 20
      }
    ],
    "Stop": [
      {
        "type": "command",
        "command": "node /root/.local/lib/agentmemory/agy-memory-hook.mjs stop",
        "timeout": 30
      }
    ]
  }
}
