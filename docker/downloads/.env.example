# Downloads Stack Environment Variables
# Copy this file to .env and fill in your values

# JDownloader2 VNC password for web interface access
# This password is required to access JDownloader2 web UI
# Use a strong password (minimum 8 characters, mix of letters/numbers/symbols)
JDOWNLOADER_VNC_PASSWORD=your_secure_vnc_password_here

# Timezone setting
TZ=Europe/Istanbul

# PUID/PGID for file permissions  
PUID=1000
PGID=1000

# Service Access Information:
# - JDownloader2 Web UI: http://your-ip:5801 (VNC password required)
# - MeTube: http://your-ip:8081 (no password required)
#
# Setup Instructions:
# 1. Set a strong VNC password above
# 2. Copy this file to .env: cp .env.example .env
# 3. Edit .env with your values: nano .env  
# 4. Deploy: docker-compose up -d