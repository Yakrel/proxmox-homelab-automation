# Utility Stack Environment Variables
# Copy this file to .env and fill in your values

# Firefox VNC password for web interface access
# This password is required to access Firefox remote browser
# Use a strong password (minimum 8 characters, mix of letters/numbers/symbols)
FIREFOX_VNC_PASSWORD=your_secure_vnc_password_here

# Homepage Dashboard API Keys
# Get these from your service settings -> API -> Generate API Key
HOMEPAGE_VAR_SONARR_API_KEY=your_sonarr_api_key_here
HOMEPAGE_VAR_RADARR_API_KEY=your_radarr_api_key_here
HOMEPAGE_VAR_PROWLARR_API_KEY=your_prowlarr_api_key_here
HOMEPAGE_VAR_BAZARR_API_KEY=your_bazarr_api_key_here
HOMEPAGE_VAR_JELLYFIN_API_KEY=your_jellyfin_api_key_here
HOMEPAGE_VAR_JELLYSEERR_API_KEY=your_jellyseerr_api_key_here

# qBittorrent Credentials (same as login)
HOMEPAGE_VAR_QB_USERNAME=admin
HOMEPAGE_VAR_QB_PASSWORD=your_qbittorrent_password_here

# Grafana Credentials
HOMEPAGE_VAR_GRAFANA_USERNAME=admin
HOMEPAGE_VAR_GRAFANA_PASSWORD=your_grafana_password_here

# Timezone setting
TZ=Europe/Istanbul

# PUID/PGID for file permissions
PUID=1000
PGID=1000

# Service Access Information:
# - Homepage Dashboard: http://your-ip:3000 (main dashboard)
# - Firefox Remote Browser: http://your-ip:5800 (VNC password required)
# - VNC Direct Access: vnc://your-ip:5900 (same password)
#
# Setup Instructions:
# 1. Set a strong VNC password above
# 2. Get API keys from your services (Sonarr, Radarr, etc.)
# 3. Copy this file to .env: cp .env.example .env
# 4. Edit .env with your values: nano .env
# 5. Deploy: docker-compose up -d
#
# Homepage Features:
# - Unified dashboard for all homelab services
# - Real-time service status and statistics
# - Quick access bookmarks and search
# - System resource monitoring
# - Weather and datetime widgets
# - Dark/light theme support
#
# Firefox Features:
# - Full remote desktop Firefox browser
# - High resolution support (1920x1080)
# - Persistent configuration and bookmarks
# - Secure VNC access