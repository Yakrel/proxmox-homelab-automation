# Proxy Stack Environment Configuration
# ===========================================
# This file contains environment variables for the proxy stack deployment.
# Copy this file to .env and customize the values for your environment.

# Timezone configuration
TZ=Europe/Istanbul

# User and Group IDs for container file permissions
PUID=1000
PGID=1000

# Cloudflared Tunnel Configuration
# ================================
# Get your tunnel token from: https://dash.cloudflare.com/
# Example: cloudflare tunnel create <tunnel-name>
CLOUDFLARED_TOKEN=changeme_cloudflare_tunnel_token

# Watchtower Configuration
# ========================
# Automatic container updates
WATCHTOWER_CLEANUP=true
WATCHTOWER_INCLUDE_STOPPED=true
WATCHTOWER_SCHEDULE=0 0 4 * * *

# Network Configuration
# =====================
# These values are typically auto-configured based on LXC container IP
PROXY_HOST_IP=192.168.1.100

# Security Configuration
# ======================
# Set to true in production for enhanced security
WATCHTOWER_NOTIFICATIONS=false

# Logging Configuration
# =====================
# Log levels: trace, debug, info, warn, error, fatal, panic
LOG_LEVEL=info