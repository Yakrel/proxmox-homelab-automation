# Media Stack Environment Variables
# This file shows required variables - actual values are in encrypted .env.enc

# Immich Configuration
UPLOAD_LOCATION=/datapool/media/immich
DB_DATA_LOCATION=/datapool/config/immich/postgres
IMMICH_VERSION=v2
DB_PASSWORD=<secure-random-password>
DB_USERNAME=postgres
DB_DATABASE_NAME=immich
IMMICH_API_KEY=<full-permission-immich-api-key>
IMMICH_URL=http://immich-server:2283
EXTERNAL_IMMICH_URL=https://immich.byetgin.com
DB_HOST=database
DB_PORT=5432
