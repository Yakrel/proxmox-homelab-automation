# Media Stack Environment Variables
# After filling in the values, encrypt this file using:
# bash scripts/encrypt-env.sh docker/media/.env

# ================================================================================
# Immich Configuration
# ================================================================================

# Immich PostgreSQL Database Password
# REQUIRED: Strong password for Immich's PostgreSQL database
# Generate with: pwgen -s 32 1
# Security: Only used for local authentication (postgres not exposed)
# Characters: Use only A-Za-z0-9 to avoid Docker parsing issues
IMMICH_DB_PASSWORD=

# ================================================================================
# Homepage Dashboard Integration
# ================================================================================

# NOTE: Immich API Key (HOMEPAGE_VAR_IMMICH_API_KEY) is configured in webtools stack
# Generate after Immich deployment:
#   1. Access Immich: http://<lxc-ip>:2283
#   2. Login as admin → Account Settings → API Keys → New API Key
#   3. Add key to docker/webtools/.env.enc (Homepage configuration)
