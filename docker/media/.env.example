# Media Stack Environment Variables
# This file shows required variables - actual values are in encrypted .env.enc

# Immich Configuration
UPLOAD_LOCATION=/datapool/media/immich
DB_DATA_LOCATION=/fastpool/config/immich/postgres
IMMICH_VERSION=v3
DB_PASSWORD=<secure-random-password>
DB_USERNAME=postgres
DB_DATABASE_NAME=immich

# Watchtower Telegram Notifications
WATCHTOWER_TELEGRAM_TOKEN=<BOT_TOKEN>
WATCHTOWER_TELEGRAM_CHAT_IDS=<CHAT_ID>
