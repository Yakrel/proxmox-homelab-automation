# Development Stack Environment Configuration  
# ===========================================
# This file contains environment variables for the development stack.
# Note: Development stack does not use Docker - this is for configuration reference only.

# Timezone configuration
TZ=Europe/Istanbul

# User and Group IDs for file permissions
PUID=1000
PGID=1000

# Node.js Configuration
# =====================
# Node.js version and package manager settings
NODE_ENV=development
NPM_CONFIG_FUND=false
NPM_CONFIG_UPDATE_NOTIFIER=false

# AI CLI Tools Configuration
# ===========================
# API keys for AI development tools (set these if using AI CLIs)
ANTHROPIC_API_KEY=your_anthropic_api_key_here
GOOGLE_API_KEY=your_google_api_key_here

# Development Tools Configuration
# ===============================
# Git configuration
GIT_USER_NAME=Developer
GIT_USER_EMAIL=developer@homelab.local

# SSH Configuration
# =================
# SSH key paths (if needed for git operations)
SSH_KEY_PATH=/root/.ssh/id_rsa

# Development Environment
# =======================
# Default shell and editor preferences  
SHELL=/bin/bash
EDITOR=nano

# Network Configuration
# =====================
# Development container network settings
DEV_HOST_IP=192.168.1.107

# Example values for reference:
# TZ=Europe/Istanbul
# NODE_ENV=development
# ANTHROPIC_API_KEY=sk-ant-api03-...
# GIT_USER_NAME=John Developer
# DEV_HOST_IP=192.168.1.107