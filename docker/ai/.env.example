# Watchtower Telegram Notifications
WATCHTOWER_TELEGRAM_TOKEN=<your-telegram-bot-token>
WATCHTOWER_TELEGRAM_CHAT_IDS=<your-telegram-chat-id>

# SSH Configuration for this LXC container
SSH_ENABLED=true
ROOT_PASSWORD=<lxc-root-password>

# OmniRoute Security Config
# JWT_SECRET generated using: openssl rand -base64 48
OMNI_JWT_SECRET=<generated-jwt-secret>

# API_KEY_SECRET generated using: openssl rand -hex 32
OMNI_API_KEY_SECRET=<generated-api-key-secret>

# Initial admin panel password
OMNI_INITIAL_PASSWORD=<generated-initial-password>

# Agentmemory OmniRoute Integration
AGENTMEMORY_OPENAI_API_KEY=<dedicated-omniroute-api-key>
AGENTMEMORY_OPENAI_BASE_URL=http://omniroute:20128/v1
AGENTMEMORY_OPENAI_MODEL=priority/agentmemory-fast-reliable
# Generate using: openssl rand -hex 32
AGENTMEMORY_SECRET=<generated-agentmemory-secret>

# Hermes Telegram Integration
# Provider, model and provider API keys are configured with the Hermes wizard.
HERMES_TELEGRAM_TOKEN=<your-hermes-telegram-token>
HERMES_TELEGRAM_CHAT_ID=<your-hermes-telegram-chat-id>

# Hermes Dashboard Basic Authentication
HERMES_DASHBOARD_BASIC_AUTH_USERNAME=<your-hermes-dashboard-username>
HERMES_DASHBOARD_BASIC_AUTH_PASSWORD=<your-hermes-dashboard-password>
