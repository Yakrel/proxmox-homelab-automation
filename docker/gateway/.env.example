# Gateway Stack Environment Variables
# This file shows required variables - actual values are in encrypted .env.enc

# Cloudflare Config
CLOUDFLARED_TOKEN=<your-cloudflare-tunnel-token>

# Watchtower Telegram Notifications
WATCHTOWER_TELEGRAM_TOKEN=<BOT_TOKEN>
WATCHTOWER_TELEGRAM_CHAT_IDS=<CHAT_ID>

# Tailscale Configuration (optional - triggers host subnet router installation)
TAILSCALE_AUTH_KEY=<your-tailscale-auth-key>
