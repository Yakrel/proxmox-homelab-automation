# Webtools Stack Environment Variables
# This file shows required variables - actual values are in encrypted .env.enc

# Desktop Workspace (unified Brave + Obsidian)
# GHCR: ghcr.io/yakrel/docker-desktop-workspace
# GitHub: Yakrel/desktop-workspace
# Optional legacy/basic auth variables if LinuxServer auth is enabled in compose.
DESKTOP_USER=<your-username>
DESKTOP_PASSWORD=<your-password>
# TOTP gate session and rate limit settings are configured in docker-compose.yml.
DESKTOP_TOTP_SECRET=<base32-totp-secret>

# Homepage API Keys
HOMEPAGE_VAR_SONARR_API_KEY=<sonarr-api-key>
HOMEPAGE_VAR_RADARR_API_KEY=<radarr-api-key>
HOMEPAGE_VAR_PROWLARR_API_KEY=<prowlarr-api-key>
HOMEPAGE_VAR_BAZARR_API_KEY=<bazarr-api-key>
HOMEPAGE_VAR_JELLYFIN_API_KEY=<jellyfin-api-key>
HOMEPAGE_VAR_NPM_USERNAME=<npm-username>
HOMEPAGE_VAR_NPM_PASSWORD=<npm-password>
HOMEPAGE_VAR_ADGUARD_USERNAME=<adguard-username>
HOMEPAGE_VAR_ADGUARD_PASSWORD=<adguard-password>
HOMEPAGE_VAR_JELLYSEERR_API_KEY=<jellyseerr-api-key>

# Immich API Key for Homepage Widget
# Required Permissions (create via Immich UI -> Account Settings -> API Keys):
#   - server.statistics
#   - asset.read
#   - asset.statistics
#   - systemMetadata.read
HOMEPAGE_VAR_IMMICH_API_KEY=<immich-api-key>

# Homepage Credentials
HOMEPAGE_VAR_QB_USERNAME=<qbittorrent-username>
HOMEPAGE_VAR_QB_PASSWORD=<qbittorrent-password>
HOMEPAGE_VAR_BACKREST_USERNAME=<backrest-username>
HOMEPAGE_VAR_BACKREST_PASSWORD=<backrest-password>

# Homepage Proxmox Integration
# NOTE: These values are auto-injected at deployment time by setup_homepage_proxmox_token()
# The token is regenerated on each deployment to ensure fresh credentials
HOMEPAGE_VAR_PROXMOX_URL=https://192.168.1.10:8006
HOMEPAGE_VAR_PROXMOX_TOKEN_ID=homepage@pve!homepage-token
HOMEPAGE_VAR_PROXMOX_TOKEN_SECRET=placeholder_will_be_set_on_deploy

# Obsidian CouchDB Sync
COUCHDB_USER=<couchdb-username>
COUCHDB_PASSWORD=<couchdb-password>


# Guacamole Remote Desktop & SSH Gateway
GUACAMOLE_USER=<your-guacamole-username>
GUACAMOLE_PASSWORD=<your-guacamole-password>
# Primary Desktop Workstation (Supports RDP for Windows/Fedora, SSH for Linux CLI)
DESKTOP_IP=<your-desktop-lan-ip>
DESKTOP_USER=<your-desktop-username>
DESKTOP_PASSWORD=<your-desktop-password>
# Laptop Workstation (Optional)
LAPTOP_IP=<your-laptop-lan-ip>
LAPTOP_RDP_USER=<your-laptop-rdp-username-optional>
LAPTOP_RDP_PASSWORD=<your-laptop-rdp-password-optional>

# Watchtower Telegram Notifications
WATCHTOWER_TELEGRAM_TOKEN=<BOT_TOKEN>
WATCHTOWER_TELEGRAM_CHAT_IDS=<CHAT_ID>

# FUTO Notes E2EE Sync Server
FUTO_POSTGRES_PASSWORD=<postgres-db-password>
FUTO_PASSWORD_HASH=<scrypt-hash-of-admin-password>
