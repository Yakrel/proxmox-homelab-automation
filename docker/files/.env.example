# Files Stack Environment Variables
# This file shows required variables - actual values are in encrypted .env.enc
#
# PASSWORD MANAGEMENT:
# - USER passwords: Set by you (for VNC access and app usage)
# - SYSTEM passwords: Fixed values (for app-specific encryption)
# - ENCRYPTION: All values stored encrypted in .env.enc, decrypt with master password

# === USER PASSWORDS (Set by you) ===
# JDownloader VNC access password - you use this to connect via VNC
JDOWNLOADER_VNC_PASSWORD=<your-vnc-password>

# === SYSTEM PASSWORDS/KEYS (Pre-configured) ===
# Palmr application encryption key - internal app security
PALMR_ENCRYPTION_KEY=<app-encryption-key>

# Palmr application URL - your app deployment URL
PALMR_APP_URL=<your-app-url>

# === IMMICH CONFIGURATION ===
# Immich photo management system
# Storage location for uploaded photos (on datapool)
IMMICH_UPLOAD_LOCATION=/datapool/immich/library

# Database storage location (on datapool)
IMMICH_DB_DATA_LOCATION=/datapool/immich/postgres

# Immich version - use 'release' for latest stable
IMMICH_VERSION=release

# Database credentials - change to secure random password
IMMICH_DB_PASSWORD=<secure-random-password>

# Database settings (defaults, usually don't need to change)
IMMICH_DB_USERNAME=postgres
IMMICH_DB_DATABASE_NAME=immich
