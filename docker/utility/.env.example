# Utility Stack Environment Variables
# This file shows required variables - actual values are in encrypted .env.enc

# JDownloader MyJDownloader Config
MYJD_USER=<your-myjdownloader-email>
MYJD_PASSWORD=<your-myjdownloader-password>
MYJD_DEVICE_NAME=<device-name>

# Samba Config
SAMBA_USER=<samba-username>
SAMBA_PASSWORD=<samba-password>

# Repackarr
REPACKARR_QBIT_HOST=<qbittorrent-host>
REPACKARR_QBIT_USERNAME=<qbittorrent-username>
REPACKARR_QBIT_PASSWORD=<qbittorrent-password>
REPACKARR_QBIT_CATEGORY=<qbittorrent-category>
REPACKARR_PROWLARR_URL=<prowlarr-url>
REPACKARR_PROWLARR_API_KEY=<prowlarr-api-key>
REPACKARR_CRON_INTERVAL_MINUTES=<cron-interval-minutes>
REPACKARR_PLATFORM_FILTER=<platform-filter>
REPACKARR_IGNORED_KEYWORDS=<ignored-keywords>
REPACKARR_ALLOWED_INDEXERS=<allowed-indexers>
REPACKARR_IGDB_CLIENT_ID=<igdb-client-id>
REPACKARR_IGDB_CLIENT_SECRET=<igdb-client-secret>

# Backrest authentication
BACKREST_AUTH_USERNAME=your-username-here
BACKREST_AUTH_PASSWORD=your-secure-password-here
BACKREST_AUTH_PASSWORD_BCRYPT=$$2b$$12$$your-bcrypt-hash-here

# Backrest restic repository
BACKREST_REPO_PASSWORD=your-repo-password
BACKREST_INSTANCE_ID=pve01-backrest-server
BACKREST_REPO_ID=pve01-repo
BACKREST_REPO_GUID=
BACKREST_SYNC_KEY_ID=your-key-id-here
BACKREST_SYNC_PRIVATE_KEY=your-private-key-here
BACKREST_SYNC_PUBLIC_KEY=your-public-key-here

# Diun Telegram Notifications
DIUN_TELEGRAM_TOKEN=<BOT_TOKEN>
DIUN_TELEGRAM_CHAT_IDS=<CHAT_ID>
DIUN_TELEGRAM_TEMPLATE_BODY=
