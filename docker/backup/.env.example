# Backup Stack (PBS) Environment Variables
# This file shows required variables - actual values are in encrypted .env.enc
#
# PASSWORD MANAGEMENT:
# - USER passwords: Set by you (for web panels you access)
# - SYSTEM passwords: Fixed random values (for service-to-service communication)
# - ENCRYPTION: All passwords stored encrypted in .env.enc, decrypt with master password

# === USER PASSWORDS (Set by you) ===
# PBS Web Admin Panel - you login here (root user password)
PBS_ADMIN_PASSWORD=<your-pbs-admin-password>

# === SYSTEM PASSWORDS (Fixed random - script manages) ===
# PBS prometheus user password - Monitoring stack uses this to scrape PBS metrics
PBS_PROMETHEUS_PASSWORD=<fixed-random-generated>

# === SYSTEM CONFIGURATION ===
# Timezone
TZ=Europe/Istanbul