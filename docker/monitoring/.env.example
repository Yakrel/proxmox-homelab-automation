# Monitoring Stack Environment Variables
# This file shows required variables - actual values are in encrypted .env.enc

# Grafana Configuration
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=<your-secure-password>

# Proxmox VE Exporter Configuration
PVE_USER=pve-exporter@pve
PVE_PASSWORD=<auto-generated-during-deployment>
PVE_URL=https://192.168.1.10:8006
PVE_VERIFY_SSL=false

# Timezone
TZ=Europe/Istanbul