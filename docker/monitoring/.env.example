# Monitoring Stack Environment Variables
# Copy this file to .env and fill in your values

# Grafana admin credentials for web interface access
# Default admin user (can be changed if needed)
GRAFANA_ADMIN_USER=admin
# This password is required to access Grafana dashboard
# Use a strong password (minimum 8 characters, mix of letters/numbers/symbols)
GRAFANA_ADMIN_PASSWORD=your_secure_grafana_password_here

# Proxmox monitoring user credentials
# Create monitoring user in Proxmox with PVEAuditor role
PVE_USER=monitoring@pve
PVE_PASSWORD=your_proxmox_monitoring_password_here
# PVE_URL will be auto-detected during interactive setup
# or manually set to your Proxmox host IP (e.g., https://192.168.1.10:8006)
PVE_URL=https://YOUR_PROXMOX_IP:8006
PVE_VERIFY_SSL=false

# Email notification settings for Alertmanager
# Gmail configuration for system alerts
GMAIL_ADDRESS=your-email@gmail.com
# Use Gmail App Password (not your regular password)
# Generate at: https://myaccount.google.com/apppasswords
GMAIL_APP_PASSWORD=your_gmail_app_password_here

# Network Configuration
# Base network for LXC containers - first three octets only (e.g., 192.168.1 for IPs 192.168.1.100-104)
# Format: X.X.X (without trailing dot)
NETWORK_BASE=192.168.1
# Grafana dashboard URL for email notifications
GRAFANA_URL=http://192.168.1.104:3000

# Timezone setting
TZ=Europe/Istanbul

# Service Access Information:
# - Grafana Dashboard: http://your-ip:3000 (admin/GRAFANA_ADMIN_PASSWORD)
# - Prometheus: http://your-ip:9090 (no authentication)
# - Alertmanager: http://your-ip:9093 (no authentication)
# - cAdvisor: http://your-ip:8080 (no authentication)
# - PVE Exporter: http://your-ip:9221 (metrics endpoint)
#
# Setup Instructions:
# 1. Create monitoring user in Proxmox:
#    - Go to Datacenter > Permissions > Users
#    - Add user: monitoring@pve
#    - Go to Datacenter > Permissions > Add
#    - Path: /, User: monitoring@pve, Role: PVEAuditor
# 2. Set strong passwords above
# 3. Configure Gmail App Password for alerts:
#    - Go to Google Account settings
#    - Enable 2-factor authentication
#    - Generate App Password for "Mail"
#    - Use that password in GMAIL_APP_PASSWORD
# 4. Update network settings if different from 192.168.1.x
# 5. Update PVE_URL with your Proxmox server IP
# 6. Copy this file to .env: cp .env.example .env
# 7. Edit .env with your values: nano .env
# 8. Deploy: docker-compose up -d
#
# Security Notes:
# - Grafana admin password is required for dashboard access
# - Proxmox credentials are used only for read-only monitoring
# - All services except Grafana have no authentication by default
# - Consider setting up reverse proxy with authentication for production
#
# Troubleshooting:
# - If PVE Exporter fails, verify Proxmox user permissions
# - If containers can't reach each other, check Docker network
# - For metric collection issues, verify node-exporter ports on other LXCs