exclude_paths:
  - config/**
  - docker/**
  - .git/**
  - .github/**

skip_list:
  # Prefer generic var names across roles; lint rule too strict for this repo
  - var-naming
  # Allow flexible task key ordering for readability (name, when, register order flexibility)
  - key-order
  # Skip command-instead-of-module for specific shell operations
  - command-instead-of-module
  # Skip schema validation for our custom platform names
  - schema[meta]

mock_modules:
  - community.general.proxmox_lxc
  - community.docker.docker_compose
  - community.docker.docker_compose_v2

mock_roles:
  - proxmox_host_setup
  - proxy
  - media
  - files
  - webtools
  - monitoring
  - development
