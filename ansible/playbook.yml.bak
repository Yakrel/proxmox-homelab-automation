---
- name: Setup all LXC containers
  hosts: lxc
  become: yes
  roles:
    - common

- name: Configure Proxy Stack
  hosts: proxy
  become: yes
  roles:
    - proxy

- name: Configure Media Stack
  hosts: media
  become: yes
  roles:
    - media

- name: Configure Monitoring Stack
  hosts: monitoring
  become: yes
  roles:
    - monitoring

- name: Configure Logging Stack
  hosts: logging
  become: yes
  roles:
    - logging
