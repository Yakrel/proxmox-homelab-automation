# Copy this file as terraform.tfvars and edit the values

# ------------------- REQUIRED SETTINGS -------------------
# Proxmox access information
proxmox_api_url  = "https://192.168.1.10:8006/api2/json"
proxmox_password = "ENTER_YOUR_PROXMOX_ROOT_PASSWORD_HERE"

# Network settings - Customize for your network
gateway = "192.168.1.1"

# -------------------- CONTAINER DEFINITIONS --------------------
# Container definitions - customize as needed
lxc_containers = [
  {
    name        = "lxc-proxy-01"
    id          = 125
    ip          = "192.168.1.125"
    memory      = 2048
    cores       = 2
    disk_size   = "8G"
    description = "Proxy Stack: Cloudflared, AdGuard Home"
  },
  {
    name        = "lxc-media-01"
    id          = 102
    ip          = "192.168.1.102"
    memory      = 16384
    cores       = 4
    disk_size   = "20G"
    description = "Media Stack: Sonarr, Radarr, Bazarr, Jellyfin, Jellyseerr, qBittorrent, Prowlarr"
  },
  {
    name        = "lxc-monitoring-01"
    id          = 103
    ip          = "192.168.1.103"
    memory      = 4096
    cores       = 2
    disk_size   = "10G"
    description = "Monitoring Stack: Prometheus, Grafana, Alertmanager, Node Exporter"
  },
  {
    name        = "lxc-logging-01"
    id          = 104
    ip          = "192.168.1.104" 
    memory      = 4096
    cores       = 2
    disk_size   = "20G"
    description = "Logging Stack: Elasticsearch, Logstash, Kibana, Filebeat"
  }
]

# -------------------- OPTIONAL SETTINGS --------------------
# You usually don't need to change the settings below
# proxmox_user = "root@pam"  # Default: root@pam
# proxmox_node = "pve01"     # Default: pve01
# nameserver = "1.1.1.1"     # Default: 1.1.1.1

# Alpine template directory and filename
alpine_template = "datapool:template/cache/alpine-3.21-default_20241217_amd64.tar.xz"

# LXC Container root password
container_password = "alpine"  # Use a secure password!

# Grafana admin password
grafana_password = "admin"  # Use a secure password!
