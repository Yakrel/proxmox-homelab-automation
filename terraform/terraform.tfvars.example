# Bu dosyayı terraform.tfvars olarak kopyalayın ve değerleri düzenleyin

# ------------------- GEREKLI AYARLAR -------------------
# Proxmox erişim bilgileri
proxmox_api_url  = "https://192.168.1.10:8006/api2/json"
proxmox_password = "PROXMOX_ROOT_ŞİFRENİZİ_BURAYA_YAZIN"

# Ağ ayarları - Kendi ağınıza göre düzenleyin
gateway = "192.168.1.1"

# -------------------- CONTAINER TANIMLARI --------------------
# Container tanımları - özelleştirebilirsiniz
lxc_containers = [
  {
    name        = "lxc-proxy-01"
    id          = 125
    ip          = "192.168.1.125"
    memory      = 2048
    cores       = 2
    disk_size   = "8G"
    description = "Proxy Stack: Cloudflared, AdGuard Home"
  },
  {
    name        = "lxc-media-01"
    id          = 102
    ip          = "192.168.1.102"
    memory      = 16384
    cores       = 4
    disk_size   = "20G"
    description = "Media Stack: Sonarr, Radarr, Bazarr, Jellyfin, Jellyseerr, qBittorrent, Prowlarr"
  },
  {
    name        = "lxc-monitoring-01"
    id          = 103
    ip          = "192.168.1.103"
    memory      = 4096
    cores       = 2
    disk_size   = "10G"
    description = "Monitoring Stack: Prometheus, Grafana, Alertmanager, Node Exporter"
  },
  {
    name        = "lxc-logging-01"
    id          = 104
    ip          = "192.168.1.104" 
    memory      = 4096
    cores       = 2
    disk_size   = "20G"
    description = "Logging Stack: Elasticsearch, Logstash, Kibana, Filebeat"
  }
]

# -------------------- İSTEĞE BAĞLI AYARLAR --------------------
# Aşağıdaki ayarları değiştirmeniz genellikle gerekmez
# proxmox_user = "root@pam"  # Varsayılan: root@pam
# proxmox_node = "pve01"     # Varsayılan: pve01
# nameserver = "1.1.1.1"     # Varsayılan: 1.1.1.1

# Alpine template dizini ve dosya adı
alpine_template = "datapool:template/cache/alpine-3.21-default_20241217_amd64.tar.xz"

# LXC Container root şifresi
container_password = "alpine"  # Güvenli bir şifre kullanın!

# Grafana admin şifresi
grafana_password = "admin"  # Güvenli bir şifre kullanın!
